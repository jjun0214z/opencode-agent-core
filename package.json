{
  "name": "agent-core-plugin",
  "version": "0.1.1",
  "description": "OpenCode plugin — NL-routed skills with 8 expert sub-agents and SQLite context storage",
  "main": "./dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.4",
    "@opencode-ai/sdk": "^1.15.4"
  },
  "devDependencies": {
    "bun-types": "1.3.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "opencode",
    "plugin",
    "agent",
    "ai",
    "code-review",
    "expert-agents"
  ],
  "author": "jjun0214z",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jjun0214z/pr-review-agent.git"
  },
  "homepage": "https://github.com/jjun0214z/pr-review-agent#readme",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.8.0"
}
